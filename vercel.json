{
  "version": 2,
  "builds": [
    { "src": "api/analyze.js", "use": "@vercel/node" },
    { "src": "api/price.js",   "use": "@vercel/node" },
    { "src": "public/**",      "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/analyze", "dest": "/api/analyze.js" },
    { "src": "/api/price",   "dest": "/api/price.js"   },
    { "src": "/(.*)",        "dest": "/public/$1"       }
  ]
}